# --- Ejecutables y Compilados ---
main
asl
*.o
**/common/*.o

# --- ANTLR: Ignorar TODO lo generado (C++ y Java) ---
# Esta regla ignora archivos que ANTLR suele generar automáticamente,
# basándose en patrones comunes de nombres.
*Lexer.h
*Lexer.cpp
*Parser.h
*Parser.cpp
*Visitor.h
*Visitor.cpp
*BaseVisitor.h
*BaseVisitor.cpp
*Listener.h
*Listener.cpp
*BaseListener.h
*BaseListener.cpp

# Archivos de soporte y tokens
*.interp
*.tokens
.antlr/

# Si usas Java (grun)
*.java
*.class
!**/src/**/*.java   # No ignorar si tienes fuentes Java manuales en una carpeta src

# --- Archivos de control de dependencias de Make ---
_antlr
_deps

# --- Archivos del Sistema y editores ---
.DS_Store
.vscode/
.idea/
*.swp
*~

# --- Notas importantes ---
# NO se ignorarán tus gramáticas (*.g4) ni tus archivos manuales (*.cpp, *.h)
# porque no coinciden con los patrones de arriba (ej: Asl.g4 o main.cpp)