# --- Ejecutables y Compilados ---
main
/CL-lab/practica/asl/asl
*.o
**/common/*.o

# --- ANTLR: Ignorar TODO lo generado (C++ y Java) ---
# Esta regla ignora archivos que ANTLR suele generar automáticamente,
# basándose en patrones comunes de nombres.

# Archivos de soporte y tokens
*.interp
*.tokens
.antlr/

# Si usas Java (grun)
*.java
*.class
!**/src/**/*.java   

# --- Archivos de control de dependencias de Make ---
_antlr
_deps

# --- Archivos del Sistema y editores ---
.DS_Store
.vscode/
.idea/
*.swp
*~

# --- Archivos generados
AslBaseVisitor.cpp
AslBaseVisitor.h
AslLexer.cpp
AslLexer.h
AslParser.h
AslParser.cpp
AslVisitor.cpp
AslVisitor.h
AslBaseVisitor.h